// Prisma schema for Reservely.
//
// Conventions (see README "Data Modeling Conventions"):
// - ids are cuid() strings
// - all tables/columns are snake_case via @@map/@map
// - every tenant-owned row carries restaurant_id
// - all monetary amounts are integer cents

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  OWNER
  MANAGER
  STAFF

  @@map("user_role")
}

enum TableStatus {
  AVAILABLE
  RESERVED
  UNAVAILABLE

  @@map("table_status")
}

enum ReservationStatus {
  PENDING
  CONFIRMED
  SEATED
  COMPLETED
  CANCELLED
  NO_SHOW

  @@map("reservation_status")
}

enum WaitlistStatus {
  WAITING
  PROMOTED
  EXPIRED
  CANCELLED

  @@map("waitlist_status")
}

enum OrderStatus {
  OPEN
  SUBMITTED
  IN_PROGRESS
  SERVED
  COMPLETED
  CANCELLED

  @@map("order_status")
}

enum PaymentMethod {
  CARD
  CASH
  ONLINE

  @@map("payment_method")
}

enum PaymentStatus {
  PENDING
  SUCCEEDED
  FAILED
  REFUNDED

  @@map("payment_status")
}

/// Tenant root. Every other entity hangs off a restaurant.
model Restaurant {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  timezone  String   @default("UTC")
  /// ISO 4217 code; amounts everywhere are integer cents of this currency
  currency  String   @default("USD")
  address   String?
  phone     String?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  users           User[]
  tables          Table[]
  menuItems       MenuItem[]
  reservations    Reservation[]
  orders          Order[]
  orderItems      OrderItem[]
  payments        Payment[]
  waitlistEntries WaitlistEntry[]

  @@map("restaurants")
}

model User {
  id           String   @id @default(cuid())
  restaurantId String   @map("restaurant_id")
  email        String
  name         String
  role         UserRole @default(STAFF)
  passwordHash String?  @map("password_hash")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  restaurant Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  @@unique([restaurantId, email])
  @@index([restaurantId])
  @@map("users")
}

model Table {
  id           String      @id @default(cuid())
  restaurantId String      @map("restaurant_id")
  number       Int
  capacity     Int
  location     String?
  status       TableStatus @default(AVAILABLE)
  createdAt    DateTime    @default(now()) @map("created_at")
  updatedAt    DateTime    @updatedAt @map("updated_at")

  restaurant   Restaurant    @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  reservations Reservation[]
  orders       Order[]

  @@unique([restaurantId, number])
  @@index([restaurantId])
  @@map("tables")
}

model MenuItem {
  id           String   @id @default(cuid())
  restaurantId String   @map("restaurant_id")
  name         String
  description  String?
  category     String
  /// price in integer cents
  priceCents   Int      @map("price_cents")
  isAvailable  Boolean  @default(true) @map("is_available")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  restaurant Restaurant  @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  orderItems OrderItem[]

  @@unique([restaurantId, name])
  @@index([restaurantId, category])
  @@map("menu_items")
}

model Reservation {
  id           String            @id @default(cuid())
  restaurantId String            @map("restaurant_id")
  tableId      String?           @map("table_id")
  guestName    String            @map("guest_name")
  guestEmail   String            @map("guest_email")
  guestPhone   String?           @map("guest_phone")
  partySize    Int               @map("party_size")
  startsAt     DateTime          @map("starts_at")
  endsAt       DateTime?         @map("ends_at")
  status       ReservationStatus @default(PENDING)
  notes        String?
  /// links the table rows of one combined (multi-table) booking; null if single
  combinationId String?          @map("combination_id")
  createdAt    DateTime          @default(now()) @map("created_at")
  updatedAt    DateTime          @updatedAt @map("updated_at")

  restaurant Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  table      Table?     @relation(fields: [tableId], references: [id], onDelete: SetNull)
  orders     Order[]

  @@index([restaurantId, startsAt])
  @@index([restaurantId, status])
  @@index([restaurantId, guestEmail])
  @@index([tableId, startsAt])
  @@index([restaurantId, combinationId])
  @@map("reservations")
}

/// A guest waiting for a fully-booked slot. When a reservation on the same slot
/// is cancelled, the oldest WAITING entry that fits the freed table is promoted
/// into a confirmed reservation. Entries EXPIRE once their slot start passes.
model WaitlistEntry {
  id            String         @id @default(cuid())
  restaurantId  String         @map("restaurant_id")
  guestName     String         @map("guest_name")
  guestEmail    String         @map("guest_email")
  guestPhone    String?        @map("guest_phone")
  partySize     Int            @map("party_size")
  startsAt      DateTime       @map("starts_at")
  endsAt        DateTime       @map("ends_at")
  status        WaitlistStatus @default(WAITING)
  /// set when promoted: the reservation created for this guest
  promotedReservationId String? @map("promoted_reservation_id")
  createdAt     DateTime       @default(now()) @map("created_at")
  updatedAt     DateTime       @updatedAt @map("updated_at")

  restaurant Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  // Promotion selects the oldest WAITING entry for a (restaurant, slot); this
  // index serves both that ordered scan and the expiry sweep.
  @@index([restaurantId, startsAt, status])
  @@index([restaurantId, status])
  @@map("waitlist_entries")
}

model Order {
  id            String      @id @default(cuid())
  restaurantId  String      @map("restaurant_id")
  reservationId String?     @map("reservation_id")
  tableId       String?     @map("table_id")
  status        OrderStatus @default(OPEN)
  /// all amounts in integer cents
  subtotalCents Int         @default(0) @map("subtotal_cents")
  taxCents      Int         @default(0) @map("tax_cents")
  tipCents      Int         @default(0) @map("tip_cents")
  totalCents    Int         @default(0) @map("total_cents")
  notes         String?
  createdAt     DateTime    @default(now()) @map("created_at")
  updatedAt     DateTime    @updatedAt @map("updated_at")

  restaurant  Restaurant   @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  reservation Reservation? @relation(fields: [reservationId], references: [id], onDelete: SetNull)
  table       Table?       @relation(fields: [tableId], references: [id], onDelete: SetNull)
  items       OrderItem[]
  payments    Payment[]

  @@index([restaurantId, status])
  @@index([restaurantId, createdAt])
  @@map("orders")
}

model OrderItem {
  id             String   @id @default(cuid())
  restaurantId   String   @map("restaurant_id")
  orderId        String   @map("order_id")
  menuItemId     String   @map("menu_item_id")
  /// snapshot of the menu item name at order time (survives renames)
  itemName       String   @map("item_name")
  quantity       Int
  /// snapshot of the menu item price at order time, integer cents
  unitPriceCents Int      @map("unit_price_cents")
  notes          String?
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  restaurant Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  order      Order      @relation(fields: [orderId], references: [id], onDelete: Cascade)
  menuItem   MenuItem   @relation(fields: [menuItemId], references: [id], onDelete: Restrict)

  @@index([restaurantId])
  @@index([orderId])
  @@map("order_items")
}

model Payment {
  id           String        @id @default(cuid())
  restaurantId String        @map("restaurant_id")
  orderId      String        @map("order_id")
  /// amount charged in integer cents (includes tip if tipCents > 0)
  amountCents  Int           @map("amount_cents")
  tipCents     Int           @default(0) @map("tip_cents")
  method       PaymentMethod
  status       PaymentStatus @default(PENDING)
  /// reference id from the external payment processor, if any
  externalRef  String?       @unique @map("external_ref")
  processedAt  DateTime?     @map("processed_at")
  createdAt    DateTime      @default(now()) @map("created_at")
  updatedAt    DateTime      @updatedAt @map("updated_at")

  restaurant Restaurant     @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  order      Order          @relation(fields: [orderId], references: [id], onDelete: Cascade)
  events     PaymentEvent[]

  @@index([restaurantId, status])
  @@index([orderId])
  @@map("payments")
}

/// Webhook delivery ledger: one row per provider event ever applied.
/// The unique event_id is what makes webhook handling idempotent — a
/// replayed delivery fails the insert and is ignored.
model PaymentEvent {
  id           String   @id @default(cuid())
  restaurantId String   @map("restaurant_id")
  paymentId    String   @map("payment_id")
  /// provider-assigned event id (the idempotency key)
  eventId      String   @unique @map("event_id")
  type         String
  createdAt    DateTime @default(now()) @map("created_at")

  payment Payment @relation(fields: [paymentId], references: [id], onDelete: Cascade)

  @@index([restaurantId])
  @@index([paymentId])
  @@map("payment_events")
}
